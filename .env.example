# ── Discord Bot Configuration ──────────────────────────────────────
# Lấy token từ: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Tiền tố lệnh bot (mặc định: !)
BOT_PREFIX=!

# ── Logging ────────────────────────────────────────────────────────
# Mức log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
